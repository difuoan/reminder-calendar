# Environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

DB_HOST=db
DB_PORT=3306
DB_NAME=calendar
DB_USER=calendar
DB_PASS=calendar

# SMTP settings
# Local dev (Mailpit): use the defaults below — no auth needed
# Production: set MAIL_HOST/PORT/USER/PASS/ENCRYPTION for your provider
#
# Gmail example:
#   MAIL_HOST=smtp.gmail.com  MAIL_PORT=587  MAIL_ENCRYPTION=tls
#   MAIL_USER=you@gmail.com   MAIL_PASS=<app-password>
#
# Brevo example:
#   MAIL_HOST=smtp-relay.brevo.com  MAIL_PORT=587  MAIL_ENCRYPTION=tls
#   MAIL_USER=you@example.com       MAIL_PASS=<brevo-smtp-key>
MAIL_HOST=mail
MAIL_PORT=1025
MAIL_ENCRYPTION=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@calendar.local
MAIL_FROM_NAME="Reminder Calendar"

# Application base URL (used for links in reminder emails)
APP_URL=http://localhost:8080
